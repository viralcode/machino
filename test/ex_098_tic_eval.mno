# Tic-tac-toe winner check.
fn winner(b: [int]) -> int
    requires len(b) == 9
{
    let lines = [[0, 1, 2], [3, 4, 5], [6, 7, 8], [0, 3, 6], [1, 4, 7], [2, 5, 8], [0, 4, 8], [2, 4, 6]]
    for i in 0..len(lines) {
        let L = lines[i]
        let a = b[L[0]]
        if a != 0 && a == b[L[1]] && a == b[L[2]] {
            return a
        }
    }
    return 0
}

fn main() {
    print(winner([1, 1, 1, 0, 2, 0, 2, 0, 0]))
}

test "ttt" {
    assert winner([1, 1, 1, 0, 2, 0, 2, 0, 0]) == 1
    assert winner([1, 2, 1, 2, 1, 2, 2, 1, 2]) == 0
}
