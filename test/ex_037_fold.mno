# Left fold.
fn fold(xs: [int], acc: int, f: fn(int, int) -> int) -> int {
    let a = acc
    for i in 0..len(xs) {
        a = f(a, xs[i])
    }
    return a
}

fn add(a: int, b: int) -> int {
    return a + b
}

fn main() {
    print(fold([1, 2, 3, 4], 0, add))
}

test "fold" {
    assert fold([1, 2, 3, 4], 0, add) == 10
}
