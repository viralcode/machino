# Singly-linked list via next indices.
struct Node {
    value: int
    next: int
}

fn list_sum(nodes: [Node], head: int) -> int {
    let s = 0
    let i = head
    while i >= 0 {
        s = s + nodes[i].value
        i = nodes[i].next
    }
    return s
}

fn main() {
    let nodes = [Node(1, 1), Node(2, 2), Node(3, -1)]
    print(list_sum(nodes, 0))
}

test "list" {
    let nodes = [Node(1, 1), Node(2, 2), Node(3, -1)]
    assert list_sum(nodes, 0) == 6
}
