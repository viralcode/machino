# Payload-free color enum.
enum Color {
    Red
    Green
    Blue
}

fn to_code(c: Color) -> int {
    return match c {
        Color::Red => 1
        Color::Green => 2
        Color::Blue => 3
    }
}

fn main() {
    print(to_code(Color::Green))
}

test "color" {
    assert to_code(Color::Red) == 1
    assert to_code(Color::Blue) == 3
}
