# Merge two sorted arrays.
fn merge(a: [int], b: [int]) -> [int] {
    let out: [int] = []
    let i = 0
    let j = 0
    while i < len(a) && j < len(b) {
        if a[i] <= b[j] {
            out = push(out, a[i])
            i = i + 1
        } else {
            out = push(out, b[j])
            j = j + 1
        }
    }
    while i < len(a) {
        out = push(out, a[i])
        i = i + 1
    }
    while j < len(b) {
        out = push(out, b[j])
        j = j + 1
    }
    return out
}

fn main() {
    let m = merge([1, 3, 5], [2, 4, 6])
    print(m[0])
    print(m[5])
}

test "merge" {
    let m = merge([1, 3, 5], [2, 4, 6])
    assert m[0] == 1
    assert m[1] == 2
    assert m[5] == 6
}
