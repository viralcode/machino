# Reverse an array in place.
fn reverse(xs: [int]) {
    let i = 0
    let j = len(xs) - 1
    while i < j {
        let t = xs[i]
        xs[i] = xs[j]
        xs[j] = t
        i = i + 1
        j = j - 1
    }
}

fn main() {
    let xs = [1, 2, 3, 4]
    reverse(xs)
    print(xs[0])
    print(xs[3])
}

test "reverse" {
    let xs = [1, 2, 3, 4]
    reverse(xs)
    assert xs[0] == 4
    assert xs[1] == 3
    assert xs[3] == 1
}
