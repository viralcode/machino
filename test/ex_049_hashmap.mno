# Generic HashMap set/get.
fn main() {
    let ks: [str] = []
    let vs: [int] = []
    let m = HashMap(ks, vs, empty_buckets(8), 8)
    hashmap_set(m, "a", 1)
    hashmap_set(m, "b", 2)
    print(hashmap_get(m, "a"))
}

test "hashmap" {
    let ks: [str] = []
    let vs: [int] = []
    let m = HashMap(ks, vs, empty_buckets(8), 8)
    hashmap_set(m, "a", 1)
    hashmap_set(m, "b", 2)
    assert hashmap_get(m, "a") == 1
    assert hashmap_get_or(m, "z", -1) == -1
    assert hashmap_len(m) == 2
}
