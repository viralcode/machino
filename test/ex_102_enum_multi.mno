# Multi-payload enum variants.
enum E {
    A
    B(int)
    C(int, str)
}

fn show(e: E) -> str {
    return match e {
        E::A => "a"
        E::B(n) => str_of_int(n)
        E::C(x, s) => str_of_int(x) + ":" + s
    }
}

fn main() {
    print(show(E::C(7, "hi")))
}

test "multi" {
    assert show(E::A) == "a"
    assert show(E::B(42)) == "42"
    assert show(E::C(7, "hi")) == "7:hi"
}
